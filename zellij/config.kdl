// Zellij configuration — https://zellij.dev/documentation/configuration
//
// Keeps Zellij's own mode system (Pane/Tab/Resize/Session/etc., entered via
// Ctrl-p/t/n/o/...) intact as a fallback, and layers a few direct,
// no-mode-switch bindings on top for the habits carried over from tmux.
// Everything else (kill pane, floating scratchpad, layout swap, sync) is
// still TBD — using Zellij's own sensible defaults for now; see #2.

theme "catppuccin-mocha"

// True color, mouse selection/resize, big scrollback — matches tmux.conf
simplified_ui false
mouse_mode true
scroll_buffer_size 100000
copy_on_select true
pane_frames true

keybinds {
    normal {
        // Vim-aware pane navigation: forwards the keystroke to Neovim (via
        // smart-splits.nvim) if it's running in the focused pane, otherwise
        // moves focus. Pinned to a specific release for reproducibility.
        bind "Ctrl h" {
            MessagePlugin "https://github.com/hiasr/vim-zellij-navigator/releases/download/0.3.0/vim-zellij-navigator.wasm" {
                name "move_focus_or_tab"
                payload "left"
                move_mod "ctrl"
            }
        }
        bind "Ctrl j" {
            MessagePlugin "https://github.com/hiasr/vim-zellij-navigator/releases/download/0.3.0/vim-zellij-navigator.wasm" {
                name "move_focus_or_tab"
                payload "down"
                move_mod "ctrl"
            }
        }
        bind "Ctrl k" {
            MessagePlugin "https://github.com/hiasr/vim-zellij-navigator/releases/download/0.3.0/vim-zellij-navigator.wasm" {
                name "move_focus_or_tab"
                payload "up"
                move_mod "ctrl"
            }
        }
        bind "Ctrl l" {
            MessagePlugin "https://github.com/hiasr/vim-zellij-navigator/releases/download/0.3.0/vim-zellij-navigator.wasm" {
                name "move_focus_or_tab"
                payload "right"
                move_mod "ctrl"
            }
        }

        // Prefix-less tab switching, matching tmux's Alt-,/Alt-.
        bind "Alt ," { GoToPreviousTab; }
        bind "Alt ." { GoToNextTab; }
    }
}

plugins {
    session-manager location="zellij:session-manager"

    // Feeds the current mode's keybinding hints into zjstatus (which, unlike
    // Zellij's own default status bar, doesn't show these on its own) — see
    // layouts/default.kdl for where it's rendered.
    zjstatus-hints location="https://github.com/b0o/zjstatus-hints/releases/download/v0.1.4/zjstatus-hints.wasm" {
        max_length 80
        overflow_str "…"
        pipe_name "zjstatus_hints"
        hide_in_base_mode true
    }
}

// zjstatus itself is NOT listed here — it's only referenced from the layout's
// pane (see layouts/default.kdl), matching its own documented setup exactly.
// It needs a real pane context to show its interactive permission prompt;
// zjstatus-hints has no pane of its own, so it's pre-granted in deploy.zsh
// instead (see grant_zellij_permissions).
load_plugins {
    zjstatus-hints
}
