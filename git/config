[http]
  sslverify = true

[user]
  email = 5483606+carpet-stain@users.noreply.github.com
  name = carpet-stain

[commit]
  template = ~/.config/git/committemplate
  verbose = true
  # gpgsign = true # Uncomment this line to enable GPG signing

[help]
  autoCorrect = 1

[alias]
  # Open a PR, only if the branch is exactly one commit ahead of origin/main —
  # the local mirror of pr-guards.yml's `single commit` gate. See
  # git-pr-link.sh; cliff.toml resolves the PR's changelog link separately,
  # via git-cliff's GitHub remote lookup, not anything done here.
  pr = "!git-pr-link"
  # Fetch origin/main fresh, then branch off it — starting from a stale
  # base is structurally impossible. See git-new.sh.
  new = "!git-new"
  # Fast-forward local main to match origin/main. Safe/loud under
  # merge.ff=only. See git-sync.sh.
  sync = "!git-sync"
  # Rebase onto origin/main, then collapse to one commit — safe regardless
  # of whether the local origin/main ref is stale or fresh going in. See
  # git-squash.sh.
  squash = "!git-squash"

[include]
  path = ~/.config/git/catppuccin.gitconfig

[push]
  default = current
  followTags = true
  # Automatically sets the upstream remote (no more --set-upstream)
  autoSetupRemote = true

[rerere]
  enabled = true

[branch]
  autoSetupRebase = always
  sort = -committerdate # recently-active branches first in `git branch`

[init]
  defaultBranch = main

[merge]
  ff = only
  conflictStyle = zdiff3

[rebase]
  autoStash = true
  autoSquash = true # auto-apply fixup!/squash! commits during interactive rebase
  updateRefs = true # update dependent branches when rebasing a stack

[color]
  ui = auto

[credential]
  helper = cache --socket ~/.cache/git-credential-cache/socket

[diff]
  colorMoved = default
  # Add specific diff drivers (if not already handled by delta)
  # This makes the config explicit about what diff logic is used for file types.
  # This relies on .gitattributes file.
  ignoreSubmodules = dirty # ignore untracked cruft inside submodules in status/diff
  submodule = log # show submodule commit summaries in diffs, not just the SHA bump
  mnemonicPrefix = true # a/b/i/w/c prefixes instead of always a/b
  renames = true

[core]
  excludesFiles = ~/.config/git/ignore
  autocrlf = input
  whitespace = cr-at-eol
  pager = delta
  untrackedCache = true

[pager]
  diff = delta
  log = delta 
  tag = sort -V

[interactive]
  diffFilter = delta --color-only

[delta]
  features = interactive catppuccin-mocha
  navigate = true     # use n and N to move between diff sections
  hyperlinks = true
  line-numbers = true

[submodule]
  fetchJobs = 5
  recurse = true

[status]
  submoduleSummary = true

[pull]
  rebase = true

[fetch]
  prune = true
  pruneTags = true

[feature]
  manyFiles = true