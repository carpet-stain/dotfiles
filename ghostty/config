# Ghostty configuration — https://ghostty.org/docs/config
#
# Ghostty's macOS defaults already provide Cmd+C/V (copy/paste), Cmd+N (new
# window), Cmd+Q (quit), Cmd+K (clear), and Cmd +/-/0 (font size), so no custom
# keybindings are needed here.

# +-------+
# | THEME |
# +-------+

# Ships built-in — exact name (with space/casing) from `ghostty +list-themes`
theme = Catppuccin Mocha

# Ghostty's auto-generated 256-color palette desaturates/misrenders some
# themes' indexed colors (see ghostty-org/ghostty#10852); use the theme's
# palette as-is.
palette-generate = false

# +------+
# | FONT |
# +------+

font-family = JetBrainsMono Nerd Font
font-size = 15

# +--------+
# | WINDOW |
# +--------+

# Borderless window
window-decoration = false
window-padding-x = 5
window-padding-y = 5
window-padding-balance = true

# +--------+
# | CURSOR |
# +--------+

cursor-style = bar
cursor-style-blink = false

# +----------+
# | BEHAVIOR |
# +----------+

# Treat both Option keys as Alt
macos-option-as-alt = true

# Keep the mouse cursor visible while typing
mouse-hide-while-typing = false

# Copy selections straight to the system clipboard
copy-on-select = clipboard
