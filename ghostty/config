# Ghostty configuration — https://ghostty.org/docs/config
#
# Ported from the previous Alacritty setup. Ghostty's macOS defaults already
# provide Cmd+C/V (copy/paste), Cmd+N (new window), Cmd+Q (quit), Cmd+K (clear),
# and Cmd +/-/0 (font size), so no custom keybindings are needed here.

# +-------+
# | THEME |
# +-------+

# Ships built-in — list with `ghostty +list-themes`
theme = catppuccin-mocha

# +------+
# | FONT |
# +------+

font-family = JetBrainsMono Nerd Font
font-size = 15

# +--------+
# | WINDOW |
# +--------+

# Borderless, matching the old decorations = "None"
window-decoration = false
window-padding-x = 5
window-padding-y = 5
window-padding-balance = true

# +--------+
# | CURSOR |
# +--------+

cursor-style = bar
cursor-style-blink = false

# +----------+
# | BEHAVIOR |
# +----------+

# Treat both Option keys as Alt (was option_as_alt = "Both")
macos-option-as-alt = true

# Keep the mouse cursor visible while typing
mouse-hide-while-typing = false

# Copy selections straight to the system clipboard (was save_to_clipboard)
copy-on-select = clipboard
