# Ghostty configuration — https://ghostty.org/docs/config
#
# Ghostty's macOS defaults already provide Cmd+C/V (copy/paste), Cmd+N (new
# window), Cmd+Q (quit), Cmd+K (clear), and Cmd +/-/0 (font size), so no custom
# keybindings are needed here.

# +-------+
# | THEME |
# +-------+

# Ships built-in — exact name (with space/casing) from `ghostty +list-themes`
theme = Catppuccin Mocha

# Ghostty's auto-generated 256-color palette desaturates/misrenders some
# themes' indexed colors (see ghostty-org/ghostty#10852); use the theme's
# palette as-is.
palette-generate = false

# +------+
# | FONT |
# +------+

font-family = JetBrainsMono Nerd Font
font-size = 15

# +--------+
# | WINDOW |
# +--------+

# Borderless window
window-decoration = false
window-padding-x = 5
window-padding-y = 5
window-padding-balance = true

# +--------+
# | CURSOR |
# +--------+

cursor-style = bar
cursor-style-blink = false

# +----------+
# | BEHAVIOR |
# +----------+

# Treat both Option keys as Alt
macos-option-as-alt = true

# Keep the mouse cursor visible while typing
mouse-hide-while-typing = false

# Copy selections straight to the system clipboard
copy-on-select = clipboard

# +-----+
# | SSH |
# +-----+

# TERM=xterm-ghostty has no terminfo entry on remote hosts, so plain SSH lands
# in a broken terminal (backspace inserts a space, apps log "terminal is
# broken"). ssh-terminfo installs Ghostty's terminfo on first connect;
# ssh-env falls back to TERM=xterm-256color where the install can't run. Both
# are off by default (no-ssh-env,no-ssh-terminfo) — the rest of this list is
# Ghostty's default feature set, restated so enabling these two doesn't drop it.
shell-integration-features = cursor,no-sudo,title,ssh-env,ssh-terminfo,path
