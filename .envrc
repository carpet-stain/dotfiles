# shellcheck shell=bash
source_env_if_exists .envrc.local

# git-cliff reads its GitHub API token from GITHUB_TOKEN, not GH_TOKEN — alias
# it to the same scoped token rather than asking for a second credential.
[[ -n "${GH_TOKEN:-}" ]] && export GITHUB_TOKEN="$GH_TOKEN"

# The vended GitHub token's Bitwarden secret UUID. Non-secret — a UUID grants
# nothing without the access token, and infra publishes it as a CI variable too
# (carpet-stain/infra's docs/CONSUMING-SECRETS.md). Keep in sync with infra's
# BWS_VENDED_SECRET_ID.
export BWS_VENDED_SECRET_ID=0ea1eb6f-cfee-4fc5-ab4f-b48e0008946e

# Fetch the rotating vended GitHub token (the sanctioned cross-repo/agent
# credential) from Bitwarden and export it as GH_VENDED_TOKEN — #377. Distinct
# from GH_TOKEN, which stays the scoped PAT (#74). Runs only when
# BWS_ACCESS_TOKEN is present (set by .zshenv from the Keychain on a provisioned
# macOS machine), so the repo still works without BWS. Fetched fresh each shell
# (the token rotates ~hourly) and never cached; bws-vended-token fails loud on a
# stale/missing token, so a dead credential surfaces here at shell entry, not as
# a 401 at first use.
if [[ -n "${BWS_ACCESS_TOKEN:-}" ]]; then
  if _vt=$(bws-vended-token "$BWS_VENDED_SECRET_ID"); then
    export GH_VENDED_TOKEN="$_vt"
  else
    log_error "vended GitHub token unavailable (see the error above) — #377"
  fi
  unset _vt
fi
