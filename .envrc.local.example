# shellcheck shell=bash
# Copy this file to .envrc.local and fill in your own token — see
# AGENTS.md's "Local tooling" section for how to create it (a fine-grained
# PAT with Contents/Pull requests/Actions read-write, NOT Administration).
# Use `env -u GH_TOKEN -u GITHUB_TOKEN gh ...` for anything that needs the
# full-admin session instead (both vars, since .envrc aliases GITHUB_TOKEN to
# this same scoped token and gh prefers it — see AGENTS.md's Credentials).
export GH_TOKEN=
