name: Lint

# The base lint workflow: language-agnostic linters only, selected via the
# lefthook `base` tag. A language overlay never touches this file — it ships
# its own workflow (e.g. test.yml) running its own tag slice with its own
# toolchain. Disjoint file ownership by design; see ADR-0020 in the template's
# source repo.
on:
  pull_request:
    types: [opened, reopened, synchronize, ready_for_review]
    branches: ["[[ protected_branch ]]"]

permissions:
  contents: read

concurrency:
  group: lint-${{ github.ref }}
  cancel-in-progress: true

jobs:
  lint:
    name: lint
    runs-on: ubuntu-latest
    # Draft PRs open early and take WIP pushes; a skipped-via-if job reads as
    # passing to required-status-check branch protection, not failing, so this
    # stays quiet until ready_for_review re-triggers it — same job-level gate
    # as pr-guards.yml.
    if: github.event.pull_request.draft == false
    steps:
      - uses: actions/checkout@v4

      # Homebrew installs the exact tools a contributor runs locally, one list,
      # no second apt/npm re-declaration. Interim: Homebrew-on-Linux is a
      # macOS-ism to redo the portable way (setup-node + pinned binaries) —
      # tracked in the follow-up issue #276.
      - name: Set up Homebrew
        uses: Homebrew/actions/setup-homebrew@master

      - name: Install lint/format tools
        run: brew install just lefthook actionlint markdownlint-cli2 prettier yamlfmt

      # `just lint` wraps `lefthook run pre-commit --all-files` — the same
      # entry point contributors run, here scoped to the base-owned jobs via
      # their lefthook tag. Locally (no tag filter) the full union runs on
      # every commit.
      - name: Run lint/format checks
        run: just lint --tag base --no-tty
