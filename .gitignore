**/.DS_Store

# Generated by deploy — root-level symlink to AGENTS.md (source of truth).
# Anchored to the repo root so it does NOT match the tracked Claude Code loader
# at claude/CLAUDE.md (that file is real content, deployed to $CLAUDE_CONFIG_DIR).
/CLAUDE.md

# Machine-specific SSH config (real hostnames/IPs, usernames) — lives at
# $XDG_CONFIG_HOME/ssh/config.local in practice, outside this repo
# entirely, so this never actually matches anything; here only as a
# safety net in case it's ever created inside the repo by mistake.
ssh/config.local

# Scoped-down GH_TOKEN for .envrc — never commit a real token
.envrc.local

# Machine-private Claude Code fragments — internal/work platform tooling that must
# never reach this public repo. Kept on-machine and deployed via symlink (the deploy
# scripts glob every fragment present). `local.md` is the private loader hook that
# claude/CLAUDE.md imports; a fresh clone lacks it and the import is skipped.
# See claude/README.md § Private fragments.
claude/fragments/local.md
claude/fragments/bytecloud.md
